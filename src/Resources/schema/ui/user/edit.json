{
  "formSchema": {
    "method": "POST",
    "action": "route('user.update', $user->id)",
    "enctype": "multipart/form-data"
  },
  "dataSchema": {
    "_token": { "type": "string", "required": true },
    "anrede_id": { "type": "integer", "required": false },
    "title": { "type": "string", "required": false },
    "firstname": { "type": "string", "required": true },
    "lastname": { "type": "string", "required": true },
    "name": { "type": "string", "required": true },
    "smallname": { "type": "string", "required": true },
    "email": { "type": "email", "required": true },
    "private_email": { "type": "email", "required": false },
    "password": { "type": "string", "required": false },
    "password2": { "type": "string", "required": false },
    "role_id": { "type": "integer", "required": true },
    "street": { "type": "string", "required": false },
    "postcode": { "type": "string", "required": false },
    "city": { "type": "string", "required": false },
    "country": { "type": "string", "required": false },
    "signature_rule_id": { "type": "integer", "required": false },
    "ustid": { "type": "string", "required": false },
    "phone": { "type": "string", "required": false },
    "phone2": { "type": "string", "required": false },
    "mobile": { "type": "string", "required": false },
    "fax": { "type": "string", "required": false },
    "skype": { "type": "string", "required": false },
    "hourly_rate": { "type": "number", "required": false },
    "birthday": { "type": "date", "required": false },
    "comment": { "type": "string", "required": false },
    "image": { "type": "file", "required": false }
  },
  "uiSchema": {
    "layout": "vertical",
    "elements": [
      { "type": "hidden", "field": "_token", "value": "csrf" },
      { "type": "combobox", "field": "anrede_id", "label": "Anrede" },
      { "type": "input", "field": "title", "label": "Title" },
      { "type": "input", "field": "firstname", "label": "Firstname" },
      { "type": "input", "field": "lastname", "label": "Lastname" },
      { "type": "input", "field": "name", "label": "Name" },
      { "type": "input", "field": "smallname", "label": "Smallname" },
      { "type": "input-email", "field": "email", "label": "Email" },
      { "type": "input-email", "field": "private_email", "label": "Private Email" },
      { "type": "input-password", "field": "password", "label": "Password", "autocomplete": "new-password" },
      { "type": "input-password", "field": "password2", "label": "Password Confirm", "autocomplete": "new-password" },
      { "type": "combobox", "field": "role_id", "label": "Role" },
      { "type": "input", "field": "street", "label": "Street" },
      { "type": "input", "field": "postcode", "label": "Postcode" },
      { "type": "input", "field": "city", "label": "City" },
      { "type": "input", "field": "country", "label": "Country" },
      { "type": "combobox", "field": "signature_rule_id", "label": "Signature Rule" },
      { "type": "input", "field": "ustid", "label": "UstID" },
      { "type": "input", "field": "phone", "label": "Phone" },
      { "type": "input", "field": "phone2", "label": "Phone 2" },
      { "type": "input", "field": "mobile", "label": "Mobile" },
      { "type": "input", "field": "fax", "label": "Fax" },
      { "type": "input", "field": "skype", "label": "Skype" },
      { "type": "input-euro", "field": "hourly_rate", "label": "Hourly Rate" },
      { "type": "input-date", "field": "birthday", "label": "Birthday" },
      { "type": "text-area", "field": "comment", "label": "Comment" },
      { "type": "input-file-img", "field": "image", "label": "Image" },
      { "type": "button", "action": "submit", "label": "Save" }
    ]
  }
}
