{
  "formSchema": {
    "method": "POST",
    "action": "route('register')",
    "enctype": ""
  },
  "dataSchema": {
    "_token": { "type": "string", "required": true },
    "name": { "type": "string", "required": true },
    "email": { "type": "email", "required": true },
    "password": { "type": "string", "required": true },
    "password_confirmation": { "type": "string", "required": true }
  },
  "uiSchema": {
    "layout": "vertical",
    "elements": [
      {
        "type": "hidden",
        "field": "_token",
        "value": "csrf"
      },
      {
        "type": "input",
        "field": "name",
        "label": "Name",
        "autocomplete": "name",
        "autofocus": true
      },
      {
        "type": "input",
        "field": "email",
        "label": "E-Mail Address",
        "autocomplete": "email"
      },
      {
        "type": "input",
        "field": "password",
        "label": "Password",
        "autocomplete": "new-password"
      },
      {
        "type": "input",
        "field": "password_confirmation",
        "label": "Confirm Password",
        "autocomplete": "new-password"
      },
      {
        "type": "button",
        "action": "submit",
        "label": "Register"
      }
    ]
  }
}
